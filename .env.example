# Database (PostgreSQL local on Hetzner VPS)
DATABASE_URL="postgresql://tinyhike:CHANGE_ME@localhost:5432/tinyhike"

# Auth (JWT pour cookies session - generate with: openssl rand -base64 32)
JWT_SECRET="CHANGE_ME"

# Anthropic API (enrichissement POI + modération photos)
ANTHROPIC_API_KEY="sk-ant-..."

# Resend (magic-link emails)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="hello@send.tinyhike.com"

# Mapbox (tiles map PWA)
MAPBOX_PUBLIC_TOKEN="pk.eyJ1..."

# Cloudflare R2 (photos storage)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="tinyhike-photos"
R2_PUBLIC_URL="https://photos.tinyhike.com"
R2_S3_ENDPOINT=""

# Telegram (digests + admin alerts)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_USER_ID=""

# App config
NODE_ENV="production"
PORT="3000"
PUBLIC_BASE_URL="https://app.tinyhike.com"
API_BASE_URL="https://api.tinyhike.com"
ACME_EMAIL="hello@tinyhike.com"
